{
    "name": "@synergetics/auth",
    "version": "1.0.0",
    "private": true,
    "type": "module",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        },
        "./react": {
            "types": "./dist/react.d.ts",
            "import": "./dist/react.js"
        }
    },
    "scripts": {
        "build": "tsc",
        "type-check": "tsc --noEmit",
        "clean": "rm -rf dist .turbo",
        "lint": "eslint src/"
    },
    "dependencies": {
        "@synergetics/types": "workspace:*",
        "next-auth": "^5.0.0-beta.25",
