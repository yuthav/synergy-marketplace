# ─── Synergetics.ai Environment Variables ────────────────────────────────
# Copy to .env.local in each app directory

# ─── Database ─────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://synergetics:synergetics@localhost:5432/synergetics_marketplace

# ─── Auth.js Secrets (one per portal) ─────────────────────────────────────
MARKETPLACE_AUTH_SECRET=your-marketplace-auth-secret-change-me
SELLER_AUTH_SECRET=your-seller-auth-secret-change-me
PLATFORM_AUTH_SECRET=your-platform-auth-secret-change-me

# ─── OAuth Providers — Marketplace ────────────────────────────────────────
MARKETPLACE_GOOGLE_CLIENT_ID=
MARKETPLACE_GOOGLE_CLIENT_SECRET=
MARKETPLACE_GITHUB_CLIENT_ID=
MARKETPLACE_GITHUB_CLIENT_SECRET=

# ─── OAuth Providers — Seller Portal ──────────────────────────────────────
SELLER_GOOGLE_CLIENT_ID=
SELLER_GOOGLE_CLIENT_SECRET=
SELLER_GITHUB_CLIENT_ID=
SELLER_GITHUB_CLIENT_SECRET=

# ─── OAuth Providers — Platform Management ────────────────────────────────
PLATFORM_GOOGLE_CLIENT_ID=
PLATFORM_GOOGLE_CLIENT_SECRET=
PLATFORM_MICROSOFT_CLIENT_ID=
PLATFORM_MICROSOFT_CLIENT_SECRET=
PLATFORM_MICROSOFT_TENANT_ID=

# ─── Stripe ───────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── Blockchain RPCs ──────────────────────────────────────────────────────
ETH_RPC_URL=https://eth.llamarpc.com
BASE_RPC_URL=https://mainnet.base.org
SOL_RPC_URL=https://api.mainnet-beta.solana.com

# ─── x402 Protocol ────────────────────────────────────────────────────────
X402_FACILITATOR_URL=https://x402.org/facilitator
X402_SIGNER_ADDRESS=0x...

# ─── API Server ───────────────────────────────────────────────────────────
API_PORT=4000
API_HOST=0.0.0.0

# ─── General ──────────────────────────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=info
